[32m+[m[32m# ServerOps AI Agent Rules (Minimal)[m
[32m+[m
[32m+[m[32m## PRIMARY GOAL[m
[32m+[m[32mBuild a minimal cross-platform (.NET 8) Blazor Server app to:[m
[32m+[m[32m- Discover and manage system services[m
[32m+[m[32m- Integrate with cloudflared tunnels[m
[32m+[m[32m- Deploy apps from GitHub releases[m
[32m+[m
[32m+[m[32m---[m
[32m+[m
[32m+[m[32m## ARCHITECTURE[m
[32m+[m
[32m+[m[32mUse simple layered structure:[m
[32m+[m
[32m+[m[32m- Domain → models only[m
[32m+[m[32m- Application → interfaces + logic[m
[32m+[m[32m- Infrastructure → OS + external integrations[m
[32m+[m[32m- Web → UI only[m
[32m+[m
[32m+[m[32mSTRICT:[m
[32m+[m[32m- No cross-layer violations[m
[32m+[m[32m- No direct shell execution in UI[m
[32m+[m[32m- All commands go through ICommandRunner[m
[32m+[m
[32m+[m[32m---[m
[32m+[m
[32m+[m[32m## PLATFORM SUPPORT[m
[32m+[m
[32m+[m[32mMust support:[m
[32m+[m[32m- Linux[m
[32m+[m[32m- Windows[m
[32m+[m
[32m+[m[32m---[m
[32m+[m
[32m+[m[32m## COMMAND RULES[m
[32m+[m
[32m+[m[32m- No arbitrary shell execution[m
[32m+[m[32m- Only predefined commands allowed[m
[32m+[m
[32m+[m[32mAllowed:[m
[32m+[m[32m- systemctl[m
[32m+[m[32m- sc[m
[32m+[m[32m- net[m
[32m+[m[32m- cloudflared[m
[32m+[m[32m- ss / netstat[m
[32m+[m
[32m+[m[32m---[m
[32m+[m
[32m+[m[32m## DEPLOYMENT RULES[m
[32m+[m
[32m+[m[32mDeployment steps:[m
[32m+[m[32m1. Stop service[m
[32m+[m[32m2. Backup current version[m
[32m+[m[32m3. Deploy new version[m
[32m+[m[32m4. Start service[m
[32m+[m
[32m+[m[32m---[m
[32m+[m
[32m+[m[32m## UI RULES[m
[32m+[m
[32m+[m[32m- Blazor Server only[m
[32m+[m[32m- Keep UI simple and functional[m
[32m+[m
[32m+[m[32m---[m
[32m+[m
[32m+[m[32m## CODING RULES[m
[32m+[m
[32m+[m[32m- Use dependency injection[m
[32m+[m[32m- Use async/await[m
[32m+[m[32m- No hardcoded paths[m
[32m+[m[32m- Keep implementation minimal[m
[32m+[m
[32m+[m[32m---[m
[32m+[m
[32m+[m[32m## OUTPUT RULES[m
[32m+[m
[32m+[m[32m- Generate complete working files[m
[32m+[m[32m- No TODO[m
[32m+[m[32m- No pseudo-code[m
