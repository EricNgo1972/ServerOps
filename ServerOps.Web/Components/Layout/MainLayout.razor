@using static Microsoft.AspNetCore.Components.Web.RenderMode
@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject NavigationManager NavigationManager

<div class="app-shell">
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-title">ServerOps</div>
            <div class="sidebar-subtitle">Platform shell</div>
        </div>

        <nav class="nav-links">
            <NavLink href="/" Match="NavLinkMatch.All">🏠 Dashboard</NavLink>
            <AuthorizeView>
                <Authorized Context="authState">
                    <NavLink href="/releases">📦 Releases</NavLink>
                    <NavLink href="/applications">🧩 Applications</NavLink>
                    <NavLink href="/exposure">🌐 Exposure</NavLink>
                    <NavLink href="/settings">⚙️ Settings</NavLink>
                    <NavLink href="/deployments">🚀 Deployments</NavLink>
                    <NavLink href="/logs">📝 Logs</NavLink>
                    @if (!IsBypassUser(authState.User))
                    {
                        <a href="" @onclick="LogoutAsync" @onclick:preventDefault="true">🔓 Logout</a>
                    }
                </Authorized>
                <NotAuthorized>
                    <NavLink href="/login">🔐 Login</NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </nav>
    </aside>

    <main class="content">
        @Body
    </main>
</div>

<LiveOperationLogDrawer @rendermode="InteractiveServer" />

@code {
    private async Task LogoutAsync()
    {
        await JS.InvokeVoidAsync("serverOpsPostJson", "/auth/logout", new { });
        NavigationManager.NavigateTo("/", forceLoad: true);
    }

    private static bool IsBypassUser(System.Security.Claims.ClaimsPrincipal user)
    {
        return user.HasClaim("bypass", "localhost");
    }
}
