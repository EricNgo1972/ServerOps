@page "/tunnels"
@inject ICloudflaredService CloudflaredService

<PageTitle>Tunnels</PageTitle>

<h1>Cloudflared</h1>

<div class="actions">
    <button @onclick="InstallAsync">Install</button>
    <button @onclick="RestartAsync">Restart</button>
</div>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <p class="message">@_message</p>
}

@if (_tunnel is null)
{
    <p>Loading tunnel data...</p>
}
else
{
    <section class="card-grid">
        <article class="card">
            <h2>Status</h2>
            <p>Installed: @_isInstalled</p>
            <p>Running: @_tunnel.IsRunning</p>
            <p>Tunnel ID: @(string.IsNullOrWhiteSpace(_tunnel.TunnelId) ? "Unavailable" : _tunnel.TunnelId)</p>
            <p>Config: @_tunnel.ConfigPath</p>
        </article>

        <article class="card">
            <h2>Ingress Rules</h2>
            @if (_tunnel.IngressRules.Count == 0)
            {
                <p>No ingress rules found.</p>
            }
            else
            {
                <ul>
                    @foreach (var rule in _tunnel.IngressRules)
                    {
                        <li>@rule</li>
                    }
                </ul>
            }
        </article>
    </section>
}

@code {
    private TunnelInfo? _tunnel;
    private bool _isInstalled;
    private string _message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isInstalled = await CloudflaredService.IsInstalledAsync();
        _tunnel = await CloudflaredService.GetTunnelInfoAsync();
    }

    private async Task InstallAsync()
    {
        var result = await CloudflaredService.InstallAsync();
        _message = result.Succeeded ? "cloudflared installed." : result.StdErr;
        await LoadAsync();
    }

    private async Task RestartAsync()
    {
        var result = await CloudflaredService.RestartAsync();
        _message = result.Succeeded ? "cloudflared restarted." : result.StdErr;
        await LoadAsync();
    }
}
