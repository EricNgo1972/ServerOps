@page "/diagnostics"
@inject IHostService HostService
@inject IPortService PortService
@inject IAppTopologyService AppTopologyService
@inject IEndpointService EndpointService
@inject IExposureService ExposureService
@inject IServiceControlService ServiceControlService

<PageTitle>Host Diagnostics</PageTitle>

<h1>Host Diagnostics</h1>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <p class="message">@_message</p>
}

@if (_services.Count == 0)
{
    <p>No services discovered.</p>
}
else
{
    <p>Current OS: @_currentOs</p>
    <p>Service count: @_services.Count</p>

    <table class="data-grid">
        <thead>
            <tr>
                <th>Name</th>
                <th>Status</th>
                <th>Actions</th>
                <th>Expose</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var service in _services)
            {
                <tr>
                    <td>@service.Name</td>
                    <td><span class="status @service.Status.ToString().ToLowerInvariant()">@service.Status</span></td>
                    <td class="actions">
                        <button @onclick="() => RunActionAsync(service.Name, ServiceControlService.StartAsync)">Start</button>
                        <button @onclick="() => RunActionAsync(service.Name, ServiceControlService.StopAsync)">Stop</button>
                        <button @onclick="() => RunActionAsync(service.Name, ServiceControlService.RestartAsync)">Restart</button>
                    </td>
                    <td class="actions">
                        <input value="@GetHostname(service.Name)" @oninput="e => SetHostname(service.Name, e.Value?.ToString())" />
                        <button @onclick="() => ExposeAsync(service.Name)">Expose</button>
                        <button @onclick="() => UpdateAsync(service.Name)">Update</button>
                        <button @onclick="() => RemoveAsync(service.Name)">Remove</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_ports.Count == 0)
{
    <p>No listening TCP ports discovered.</p>
}
else
{
    <h2>Listening Ports</h2>
    <table class="data-grid">
        <thead>
            <tr>
                <th>Port</th>
                <th>PID</th>
                <th>Process/Service</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var port in _ports)
            {
                <tr>
                    <td>@port.Port</td>
                    <td>@(port.ProcessId?.ToString() ?? "-")</td>
                    <td>@(string.IsNullOrWhiteSpace(port.ProcessName) ? "-" : port.ProcessName)</td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_topology.Count == 0)
{
    <p>No service topology discovered.</p>
}
else
{
    <h2>Service Topology</h2>
    <table class="data-grid">
        <thead>
            <tr>
                <th>Service</th>
                <th>Status</th>
                <th>PID</th>
                <th>Ports</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in _topology)
            {
                <tr>
                    <td>@item.ServiceName</td>
                    <td><span class="status @item.Status.ToString().ToLowerInvariant()">@item.Status</span></td>
                    <td>@(item.ProcessId?.ToString() ?? "-")</td>
                    <td>@(item.Ports.Count == 0 ? "-" : string.Join(", ", item.Ports))</td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_endpoints.Count == 0)
{
    <p>No endpoint mappings discovered.</p>
}
else
{
    <h2>Endpoints</h2>
    <table class="data-grid">
        <thead>
            <tr>
                <th>Service</th>
                <th>Port</th>
                <th>URL</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var endpoint in _endpoints)
            {
                <tr>
                    <td>@endpoint.ServiceName</td>
                    <td>@(endpoint.Port?.ToString() ?? "-")</td>
                    <td>@(string.IsNullOrWhiteSpace(endpoint.PublicUrl) ? "-" : endpoint.PublicUrl)</td>
                    <td>@(endpoint.IsExposed ? "Exposed" : "Not Exposed")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private OsType _currentOs;
    private List<ServiceInfo> _services = [];
    private List<PortInfo> _ports = [];
    private List<ServiceTopology> _topology = [];
    private List<ServiceEndpoint> _endpoints = [];
    private Dictionary<string, string> _hostnames = new(StringComparer.OrdinalIgnoreCase);
    private string _message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _currentOs = HostService.GetCurrentOs();
        _services = (await HostService.GetServicesAsync()).ToList();
        _ports = (await PortService.GetListeningPortsAsync()).OrderBy(x => x.Port).ToList();
        _topology = (await AppTopologyService.GetTopologyAsync()).ToList();
        _endpoints = (await EndpointService.GetEndpointsAsync()).ToList();
    }

    private async Task RunActionAsync(string serviceName, Func<string, CancellationToken, Task<CommandResult>> action)
    {
        var result = await action(serviceName, CancellationToken.None);
        _message = $"ExitCode: {result.ExitCode} | StdOut: {result.StdOut} | StdErr: {result.StdErr}";
        await LoadAsync();
    }

    private string GetHostname(string serviceName)
        => _hostnames.TryGetValue(serviceName, out var hostname) ? hostname : string.Empty;

    private void SetHostname(string serviceName, string? hostname)
    {
        _hostnames[serviceName] = hostname ?? string.Empty;
    }

    private async Task ExposeAsync(string serviceName)
    {
        try
        {
            await ExposureService.ExposeAsync(serviceName, GetHostname(serviceName), CancellationToken.None);
            _message = $"Exposure configured for {serviceName}.";
        }
        catch (Exception ex)
        {
            _message = ex.Message;
        }

        await LoadAsync();
    }

    private async Task UpdateAsync(string serviceName)
    {
        try
        {
            await ExposureService.UpdateAsync(serviceName, GetHostname(serviceName), CancellationToken.None);
            _message = $"Exposure updated for {serviceName}.";
        }
        catch (Exception ex)
        {
            _message = ex.Message;
        }

        await LoadAsync();
    }

    private async Task RemoveAsync(string serviceName)
    {
        try
        {
            await ExposureService.UnexposeAsync(serviceName, CancellationToken.None);
            _message = $"Exposure removed for {serviceName}.";
        }
        catch (Exception ex)
        {
            _message = ex.Message;
        }

        await LoadAsync();
    }
}
