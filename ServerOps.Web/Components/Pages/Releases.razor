@page "/releases"
@inject IGitHubService GitHubService
@inject IDeploymentService DeploymentService
@inject IDeploymentHistoryStore DeploymentHistoryStore
@inject IRollbackService RollbackService

<PageTitle>Releases</PageTitle>

<h1>GitHub Releases</h1>

<EditForm Model="_query" OnValidSubmit="SearchAsync">
    <div class="form-row">
        <label for="repo">Repository</label>
        <InputText id="repo" @bind-Value="_query.Repo" />
    </div>
    <div class="form-row">
        <label for="app">Application Name</label>
        <InputText id="app" @bind-Value="_deployment.AppName" />
    </div>
    <div class="form-row">
        <label for="assetUrl">Asset URL</label>
        <InputText id="assetUrl" @bind-Value="_deployment.AssetUrl" />
    </div>
    <button type="submit">Load Releases</button>
    <button type="button" @onclick="DeployFromInputAsync">Deploy</button>
</EditForm>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <p class="message">@_message</p>
}

@if (_releases.Count > 0)
{
    <div class="release-list">
        @foreach (var release in _releases)
        {
            <article class="card">
                <h2>@(string.IsNullOrWhiteSpace(release.Name) ? release.Tag : release.Name)</h2>
                <p>Tag: @release.Tag</p>
                <p>Published: @release.PublishedAt.ToLocalTime()</p>

                @if (release.Assets.Count == 0)
                {
                    <p>No assets.</p>
                }
                else
                {
                    <ul>
                        @foreach (var asset in release.Assets)
                        {
                            <li>
                                @asset.Name (@asset.Size bytes)
                                <button @onclick="() => DeployAsync(asset.DownloadUrl)">Deploy</button>
                            </li>
                        }
                    </ul>
                }
            </article>
        }
    </div>
}

@if (_deploymentResult is not null)
{
    <article class="card">
        <h2>Deployment Result</h2>
        <p>Status: @_deploymentResult.Status</p>
        <p>Stage: @_deploymentResult.Stage</p>
        <p>Message: @(string.IsNullOrWhiteSpace(_deploymentResult.Message) ? "-" : _deploymentResult.Message)</p>
        <p>Started: @_deploymentResult.StartedAtUtc.ToLocalTime()</p>
        <p>Finished: @(_deploymentResult.FinishedAtUtc?.ToLocalTime().ToString() ?? "-")</p>
    </article>
}

@if (_history.Count > 0)
{
    <article class="card">
        <h2>Deployment History</h2>
        <table class="data-grid">
            <thead>
                <tr>
                    <th>Deployment ID</th>
                    <th>Version</th>
                    <th>Status</th>
                    <th>Stage</th>
                    <th>Started</th>
                    <th>Finished</th>
                    <th>Message</th>
                    <th>Rollback</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in OrderedHistory)
                {
                    <tr class="@(IsLatest(item) ? "latest-deployment" : null)">
                        <td>@item.DeploymentId</td>
                        <td>@item.Version</td>
                        <td>@item.Status</td>
                        <td>@item.Stage</td>
                        <td>@item.StartedAtUtc.ToLocalTime()</td>
                        <td>@(item.FinishedAtUtc?.ToLocalTime().ToString() ?? "-")</td>
                        <td>@(string.IsNullOrWhiteSpace(item.Message) ? "-" : item.Message)</td>
                        <td>
                            @if (CanRollback(item))
                            {
                                <button @onclick="() => RollbackAsync(item.DeploymentId)">Rollback</button>
                            }
                            else
                            {
                                <button disabled>Rollback</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </article>
}

@code {
    private readonly ReleaseQueryDto _query = new();
    private readonly DeploymentRequestDto _deployment = new();
    private List<ReleaseInfo> _releases = [];
    private List<DeploymentHistoryItem> _history = [];
    private DeploymentResult? _deploymentResult;
    private string _message = string.Empty;
    private IReadOnlyList<DeploymentHistoryItem> OrderedHistory
        => _history.OrderByDescending(x => x.StartedAtUtc).ToList();

    private async Task SearchAsync()
    {
        _releases = (await GitHubService.GetReleasesAsync(_query.Repo)).ToList();
        await LoadHistoryAsync();
        _message = _releases.Count == 0 ? "No releases found." : string.Empty;
    }

    private async Task DeployAsync(string assetUrl)
    {
        if (string.IsNullOrWhiteSpace(_deployment.AppName))
        {
            _message = "Application name is required.";
            return;
        }

        _deployment.AssetUrl = assetUrl;
        _deploymentResult = await DeploymentService.DeployAsync(_deployment.AppName, assetUrl);
        await LoadHistoryAsync();
        _message = $"{_deploymentResult.AppName} deployment {_deploymentResult.Status} at {_deploymentResult.StartedAtUtc.LocalDateTime}.";
    }

    private async Task DeployFromInputAsync()
    {
        if (string.IsNullOrWhiteSpace(_deployment.AssetUrl))
        {
            _message = "Asset URL is required.";
            return;
        }

        await DeployAsync(_deployment.AssetUrl);
    }

    private async Task RollbackAsync(string deploymentId)
    {
        if (string.IsNullOrWhiteSpace(_deployment.AppName))
        {
            _message = "Application name is required.";
            return;
        }

        _deploymentResult = await RollbackService.RollbackAsync(_deployment.AppName, deploymentId);
        await LoadHistoryAsync();
        _message = $"{_deploymentResult.AppName} rollback {_deploymentResult.Status} at {_deploymentResult.StartedAtUtc.LocalDateTime}.";
    }

    private async Task LoadHistoryAsync()
    {
        if (string.IsNullOrWhiteSpace(_deployment.AppName))
        {
            _history = [];
            return;
        }

        _history = (await DeploymentHistoryStore.GetByAppAsync(_deployment.AppName)).ToList();
    }

    private bool IsLatest(DeploymentHistoryItem item)
        => OrderedHistory.Count > 0 && string.Equals(OrderedHistory[0].DeploymentId, item.DeploymentId, StringComparison.OrdinalIgnoreCase);

    private bool CanRollback(DeploymentHistoryItem item)
    {
        return item.Status == DeploymentStatus.Succeeded
            && !item.IsRollback
            && !string.IsNullOrWhiteSpace(item.BackupPath)
            && !IsLatest(item);
    }
}
