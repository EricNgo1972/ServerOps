@page "/releases"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@inject ICompanyAppRegistry CompanyAppRegistry
@inject IDomainSuffixRegistry DomainSuffixRegistry
@inject IEndpointService EndpointService
@inject IHostService HostService
@inject IGitHubService GitHubService
@inject IOneClickDeployService OneClickDeployService
@inject IDomainNameBuilder DomainNameBuilder

<PageTitle>Releases</PageTitle>

<div class="releases-shell">
    <header class="page-header">
        <div>
            <h1>Releases</h1>
            <p>Browse GitHub releases and perform one-click deployment.</p>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="page-status error">
            <strong>Unable to complete the request.</strong>
            <span>@_errorMessage</span>
        </div>
    }

    @if (_deployResult is not null)
    {
        <div class="page-status @(_deployResult.Exposed ? "success" : "info")">
            <strong>@_deployResult.Deployment.Status</strong>
            <span>@(_deployResult.Message ?? "Deployment completed.")</span>
            @if (!string.IsNullOrWhiteSpace(_deployResult.PublicUrl))
            {
                <span>@_deployResult.PublicUrl</span>
            }
        </div>
    }

    <section class="releases-toolbar">
        <label class="field">
            <span>Application</span>
            <select value="@_selectedAppName" @onchange="OnSelectedAppChangedAsync" disabled="@_isLoadingReleases">
                <option value="">Select an application</option>
                @foreach (var app in _apps)
                {
                    <option value="@app.Name">@(string.IsNullOrWhiteSpace(app.DisplayName) ? app.Name : app.DisplayName)</option>
                }
            </select>
        </label>

        @if (_selectedApp is not null)
        {
            <div class="selection-banner">
                <strong>Selected application:</strong>
                <span>@(string.IsNullOrWhiteSpace(_selectedApp.DisplayName) ? _selectedApp.Name : _selectedApp.DisplayName)</span>
            </div>
        }
    </section>

    <section class="releases-layout">
        <article class="releases-panel">
            <div class="panel-heading">
                <h2>Releases</h2>
                <span class="subtle">Showing @CurrentOsLabel assets only</span>
            </div>

            @if (_selectedApp is null)
            {
                <p class="empty-text">Select an application to view releases</p>
            }
            else if (_isLoadingReleases)
            {
                <ActivityIndicator Title="Loading releases" Message="Fetching GitHub releases for the selected application." />
            }
            else if (_releases.Count == 0)
            {
                <p class="empty-text">No releases found</p>
            }
            else
            {
                <div class="release-list">
                    @foreach (var release in _releases)
                    {
                        var isSelectedRelease = ReferenceEquals(_selectedRelease, release);
                        var primaryAsset = release.Assets.FirstOrDefault();

                        <div class="release-item @(isSelectedRelease ? "selected" : string.Empty)">
                            <button type="button" class="release-button" @onclick="() => SelectRelease(release)">
                                <span class="release-main">
                                    <span class="release-date">@FormatReleaseDate(release.PublishedAt)</span>
                                    <span class="release-name">@release.Name</span>
                                    <span class="release-meta">@release.Tag</span>
                                </span>
                                <span class="release-size">@(primaryAsset is null ? "No assets" : FormatSize(primaryAsset.Size))</span>
                            </button>
                        </div>
                    }
                </div>
            }
        </article>

        <aside class="action-panel">
            <div class="panel-heading">
                <h2>Deploy</h2>
            </div>

            <dl class="summary-list">
                <div>
                    <dt>Application</dt>
                    <dd>@(_selectedApp is null ? "-" : string.IsNullOrWhiteSpace(_selectedApp.DisplayName) ? _selectedApp.Name : _selectedApp.DisplayName)</dd>
                </div>
                <div>
                    <dt>Asset</dt>
                    <dd>@(_selectedAsset?.Name ?? "-")</dd>
                </div>
            </dl>

            <label class="field">
                <span>Port override</span>
                <input value="@_portOverrideText" @oninput="OnPortOverrideChanged" inputmode="numeric" />
            </label>

            @if (!IsPortOverrideValid)
            {
                <div class="hostname-warning">Enter a port between 1 and 65535.</div>
            }

            <label class="toggle">
                <input type="checkbox" @bind="_exposePublicly" />
                <span>Expose publicly</span>
            </label>

            @if (_exposePublicly && _selectedApp is not null)
            {
                <div class="hostname-editor">
                    <label class="field">
                        <span>Host label</span>
                        <input value="@_hostLabel" @oninput="OnHostLabelChanged" />
                    </label>

                    <label class="field">
                        <span>Domain suffix</span>
                        <select value="@_selectedDomainSuffix" @onchange="OnDomainSuffixChanged">
                            <option value="">Select a domain suffix</option>
                            @foreach (var suffix in _domainSuffixes)
                            {
                                <option value="@suffix">@suffix</option>
                            }
                        </select>
                    </label>

                    <div class="hostname-preview">
                        Hostname: @(SelectedHostname ?? "-")
                    </div>

                    @if (_domainSuffixes.Count == 0)
                    {
                        <div class="hostname-warning">No domain suffixes are available.</div>
                    }
                    else if (!IsHostnameValid)
                    {
                        <div class="hostname-warning">Enter a valid hostname label and select a domain suffix.</div>
                    }
                    else if (IsDuplicateHostname)
                    {
                        <div class="hostname-warning">This hostname is already assigned to another app.</div>
                    }
                </div>
            }

            <button type="button"
                    class="deploy-button"
                    @onclick="DeployAsync"
                    disabled="@(!CanDeploy || _isDeploying)">
                @(_isDeploying ? "Deploying..." : "Deploy")
            </button>

            @if (_isDeploying)
            {
                <div class="deploy-activity">
                    <ActivityIndicator Title="Deploying" Message="Submitting one-click deployment request." />
                </div>
            }
        </aside>
    </section>
</div>

@code {
    private IReadOnlyList<ServerOps.Application.Models.CompanyApp> _apps = Array.Empty<ServerOps.Application.Models.CompanyApp>();
    private IReadOnlyList<ReleaseInfo> _releases = Array.Empty<ReleaseInfo>();
    private ServerOps.Application.Models.CompanyApp? _selectedApp;
    private ServerOps.Domain.Enums.OsType _currentOs;
    private string _selectedAppName = string.Empty;
    private ReleaseInfo? _selectedRelease;
    private ReleaseAsset? _selectedAsset;
    private bool _isLoadingReleases;
    private bool _isDeploying;
    private bool _exposePublicly;
    private string _portOverrideText = string.Empty;
    private IReadOnlyList<string> _domainSuffixes = Array.Empty<string>();
    private string _selectedDomainSuffix = string.Empty;
    private string _hostLabel = string.Empty;
    private HashSet<string> _existingHostnames = new(StringComparer.OrdinalIgnoreCase);
    private string _errorMessage = string.Empty;
    private OneClickDeployResult? _deployResult;

    protected override async Task OnInitializedAsync()
    {
        _currentOs = HostService.GetCurrentOs();
        _apps = (await CompanyAppRegistry.GetAppsAsync())
            .OrderBy(app => app.DisplayName ?? app.Name, StringComparer.OrdinalIgnoreCase)
            .ThenBy(app => app.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

        _domainSuffixes = await DomainSuffixRegistry.GetSuffixesAsync();
        _selectedDomainSuffix = _domainSuffixes.FirstOrDefault() ?? string.Empty;
        _existingHostnames = (await EndpointService.GetEndpointsAsync())
            .Where(endpoint => !string.IsNullOrWhiteSpace(endpoint.Hostname))
            .Select(endpoint => endpoint.Hostname!.Trim().ToLowerInvariant())
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    private bool CanDeploy =>
        _selectedApp is not null &&
        _selectedAsset is not null &&
        IsPortOverrideValid &&
        (!_exposePublicly || (IsHostnameValid && !IsDuplicateHostname));

    private string SanitizedHostLabel => DomainNameBuilder.SanitizeLabel(_hostLabel);

    private bool IsHostnameValid =>
        !string.IsNullOrWhiteSpace(SanitizedHostLabel) &&
        !string.IsNullOrWhiteSpace(_selectedDomainSuffix);

    private string? SelectedHostname =>
        !IsHostnameValid ? null : DomainNameBuilder.Build(_hostLabel, _selectedDomainSuffix);

    private bool IsDuplicateHostname =>
        !string.IsNullOrWhiteSpace(SelectedHostname) &&
        _existingHostnames.Contains(SelectedHostname);

    private int? PortOverride =>
        int.TryParse(_portOverrideText, out var port) && port is >= 1 and <= 65535 ? port : null;

    private bool IsPortOverrideValid =>
        string.IsNullOrWhiteSpace(_portOverrideText) ||
        PortOverride.HasValue;

    private string CurrentOsLabel =>
        _currentOs == ServerOps.Domain.Enums.OsType.Windows ? "Windows" : "Linux";

    private async Task OnSelectedAppChangedAsync(ChangeEventArgs args)
    {
        _selectedAppName = args.Value?.ToString() ?? string.Empty;
        _errorMessage = string.Empty;
        _deployResult = null;
        _selectedRelease = null;
        _selectedAsset = null;
        _releases = Array.Empty<ReleaseInfo>();

        _selectedApp = _apps.FirstOrDefault(app =>
            string.Equals(app.Name, _selectedAppName, StringComparison.OrdinalIgnoreCase));

        if (_selectedApp is null)
        {
            _hostLabel = string.Empty;
            return;
        }

        _hostLabel = DomainNameBuilder.SanitizeLabel(_selectedApp.Name);

        var repo = ExtractRepo(_selectedApp.RepoUrl);
        if (string.IsNullOrWhiteSpace(repo))
        {
            _errorMessage = "The selected application does not have a valid GitHub repository.";
            return;
        }

        _isLoadingReleases = true;

        try
        {
            var result = await GitHubService.GetReleasesAsync(repo);
            if (!result.Succeeded)
            {
                _errorMessage = result.ErrorMessage ?? "Unable to load releases from GitHub.";
                return;
            }

            _releases = FilterReleasesForCurrentOs(result.Releases, _currentOs);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoadingReleases = false;
        }
    }

    private void SelectRelease(ReleaseInfo release)
    {
        if (ReferenceEquals(_selectedRelease, release))
        {
            _selectedRelease = null;
            _selectedAsset = null;
            return;
        }

        _selectedRelease = release;
        _selectedAsset = release.Assets.FirstOrDefault();
    }

    private void OnHostLabelChanged(ChangeEventArgs args)
    {
        _hostLabel = args.Value?.ToString() ?? string.Empty;
    }

    private void OnDomainSuffixChanged(ChangeEventArgs args)
    {
        _selectedDomainSuffix = args.Value?.ToString() ?? string.Empty;
    }

    private void OnPortOverrideChanged(ChangeEventArgs args)
    {
        _portOverrideText = args.Value?.ToString() ?? string.Empty;
    }

    private async Task DeployAsync()
    {
        if (_selectedApp is null || _selectedAsset is null)
        {
            return;
        }

        var repo = ExtractRepo(_selectedApp.RepoUrl);
        if (string.IsNullOrWhiteSpace(repo))
        {
            _errorMessage = "The selected application does not have a valid GitHub repository.";
            return;
        }

        _errorMessage = string.Empty;
        _deployResult = null;
        _isDeploying = true;

        try
        {
            _deployResult = await OneClickDeployService.DeployAsync(new OneClickDeployRequest
            {
                Repo = repo,
                AppName = _selectedApp.Name,
                AssetUrl = _selectedAsset.DownloadUrl,
                PortOverride = PortOverride,
                AutoGenerateHostname = false,
                DomainSuffix = _exposePublicly ? _selectedDomainSuffix : null,
                Hostname = _exposePublicly ? SelectedHostname : null
            });
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isDeploying = false;
        }
    }

    private static string ExtractRepo(string? repoUrl)
    {
        if (string.IsNullOrWhiteSpace(repoUrl))
        {
            return string.Empty;
        }

        if (!Uri.TryCreate(repoUrl, UriKind.Absolute, out var uri))
        {
            return repoUrl.Trim().Trim('/');
        }

        var segments = uri.AbsolutePath.Trim('/').Split('/', StringSplitOptions.RemoveEmptyEntries);
        if (segments.Length < 2)
        {
            return string.Empty;
        }

        return $"{segments[0]}/{segments[1]}";
    }

    private static string FormatSize(long size)
    {
        if (size >= 1024L * 1024L)
        {
            return $"{size / 1024d / 1024d:0.#} MB";
        }

        if (size >= 1024L)
        {
            return $"{size / 1024d:0.#} KB";
        }

        return $"{size} B";
    }

    private static string FormatReleaseDate(DateTimeOffset publishedAt)
    {
        return publishedAt == DateTimeOffset.MinValue
            ? "-"
            : publishedAt.ToLocalTime().ToString("yyyy-MM-dd");
    }

    private static IReadOnlyList<ReleaseInfo> FilterReleasesForCurrentOs(
        IReadOnlyList<ReleaseInfo> releases,
        ServerOps.Domain.Enums.OsType currentOs)
    {
        return releases
            .Select(release =>
            {
                var assets = release.Assets
                    .Where(asset => AssetMatchesOs(asset.Name, currentOs))
                    .ToList();

                return new ReleaseInfo
                {
                    Name = release.Name,
                    Tag = release.Tag,
                    PublishedAt = release.PublishedAt,
                    Assets = assets
                };
            })
            .Where(release => release.Assets.Count > 0)
            .ToList();
    }

    private static bool AssetMatchesOs(string assetName, ServerOps.Domain.Enums.OsType currentOs)
    {
        if (string.IsNullOrWhiteSpace(assetName))
        {
            return false;
        }

        return currentOs switch
        {
            ServerOps.Domain.Enums.OsType.Windows =>
                assetName.Contains("windows", StringComparison.OrdinalIgnoreCase) ||
                assetName.Contains("win", StringComparison.OrdinalIgnoreCase),
            ServerOps.Domain.Enums.OsType.Linux => assetName.Contains("linux", StringComparison.OrdinalIgnoreCase),
            _ => false
        };
    }
}
