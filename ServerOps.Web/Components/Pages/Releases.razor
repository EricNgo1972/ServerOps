@page "/releases"
@inject IGitHubService GitHubService
@inject IOneClickDeployService OneClickDeployService
@inject IDeploymentHistoryStore DeploymentHistoryStore
@inject IRollbackService RollbackService

<PageTitle>Releases</PageTitle>

<h1>GitHub Releases</h1>

<EditForm Model="_request" OnValidSubmit="SearchAsync">
    <div class="form-row">
        <label for="repo">Repository</label>
        <InputText id="repo" @bind-Value="_request.Repo" />
    </div>
    <div class="form-row">
        <label for="app">Application Name</label>
        <InputText id="app" @bind-Value="_request.AppName" />
    </div>
    <div class="form-row">
        <label for="assetUrl">Asset URL</label>
        <InputText id="assetUrl" @bind-Value="_request.AssetUrl" />
    </div>
    <div class="form-row">
        <label for="hostname">Hostname</label>
        <InputText id="hostname" @bind-Value="_request.Hostname" disabled="@_request.AutoGenerateHostname" />
    </div>
    <div class="form-row">
        <label for="auto-hostname">Auto-generate hostname</label>
        <InputCheckbox id="auto-hostname" @bind-Value="_request.AutoGenerateHostname" />
    </div>
    <button type="submit">Load Releases</button>
    <button type="button" @onclick="DeployFromInputAsync">One-Click Deploy</button>
</EditForm>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <p class="message">@_message</p>
}

@if (_releases.Count > 0)
{
    <div class="release-list">
        @foreach (var release in _releases)
        {
            <article class="card">
                <h2>@(string.IsNullOrWhiteSpace(release.Name) ? release.Tag : release.Name)</h2>
                <p>Tag: @release.Tag</p>
                <p>Published: @release.PublishedAt.ToLocalTime()</p>

                @if (release.Assets.Count == 0)
                {
                    <p>No assets.</p>
                }
                else
                {
                    <ul>
                        @foreach (var asset in release.Assets)
                        {
                            <li>
                                @asset.Name (@asset.Size bytes)
                                <button @onclick="() => OneClickDeployAsync(asset.DownloadUrl)">One-Click Deploy</button>
                            </li>
                        }
                    </ul>
                }
            </article>
        }
    </div>
}

@if (_oneClickResult is not null)
{
    <article class="card">
        <h2>One-Click Deploy Result</h2>
        <p>Deployment Status: @_oneClickResult.Deployment.Status</p>
        <p>Deployment Stage: @_oneClickResult.Deployment.Stage</p>
        <p>Hostname: @(_oneClickResult.Hostname ?? "-")</p>
        <p>Public URL: @(_oneClickResult.PublicUrl ?? "-")</p>
        <p>Exposure Status: @(_oneClickResult.Exposed ? "Exposed" : "Not Exposed")</p>
        <p>Message: @(string.IsNullOrWhiteSpace(_oneClickResult.Message) ? "-" : _oneClickResult.Message)</p>
    </article>
}

@if (_history.Count > 0)
{
    <article class="card">
        <h2>Deployment History</h2>
        <table class="data-grid">
            <thead>
                <tr>
                    <th>Deployment ID</th>
                    <th>Version</th>
                    <th>Status</th>
                    <th>Stage</th>
                    <th>Started</th>
                    <th>Finished</th>
                    <th>Message</th>
                    <th>Rollback</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in OrderedHistory)
                {
                    <tr class="@(IsLatest(item) ? "latest-deployment" : null)">
                        <td>@item.DeploymentId</td>
                        <td>@item.Version</td>
                        <td>@item.Status</td>
                        <td>@item.Stage</td>
                        <td>@item.StartedAtUtc.ToLocalTime()</td>
                        <td>@(item.FinishedAtUtc?.ToLocalTime().ToString() ?? "-")</td>
                        <td>@(string.IsNullOrWhiteSpace(item.Message) ? "-" : item.Message)</td>
                        <td>
                            @if (CanRollback(item))
                            {
                                <button @onclick="() => RollbackAsync(item.DeploymentId)">Rollback</button>
                            }
                            else
                            {
                                <button disabled>Rollback</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </article>
}

@code {
    private readonly OneClickDeployRequest _request = new() { AutoGenerateHostname = true };
    private List<ReleaseInfo> _releases = [];
    private List<DeploymentHistoryItem> _history = [];
    private OneClickDeployResult? _oneClickResult;
    private string _message = string.Empty;
    private IReadOnlyList<DeploymentHistoryItem> OrderedHistory
        => _history.OrderByDescending(x => x.StartedAtUtc).ToList();

    private async Task SearchAsync()
    {
        _releases = (await GitHubService.GetReleasesAsync(_request.Repo)).ToList();
        await LoadHistoryAsync();
        _message = _releases.Count == 0 ? "No releases found." : string.Empty;
    }

    private async Task OneClickDeployAsync(string assetUrl)
    {
        if (string.IsNullOrWhiteSpace(_request.AppName))
        {
            _message = "Application name is required.";
            return;
        }

        _request.AssetUrl = assetUrl;
        _oneClickResult = await OneClickDeployService.DeployAsync(_request);
        await LoadHistoryAsync();
        _message = _oneClickResult.Message ?? string.Empty;
    }

    private async Task DeployFromInputAsync()
    {
        if (string.IsNullOrWhiteSpace(_request.AssetUrl))
        {
            _message = "Asset URL is required.";
            return;
        }

        await OneClickDeployAsync(_request.AssetUrl);
    }

    private async Task RollbackAsync(string deploymentId)
    {
        if (string.IsNullOrWhiteSpace(_request.AppName))
        {
            _message = "Application name is required.";
            return;
        }

        var rollbackResult = await RollbackService.RollbackAsync(_request.AppName, deploymentId);
        _oneClickResult = new OneClickDeployResult
        {
            Deployment = rollbackResult,
            Exposed = false,
            Message = rollbackResult.Message
        };
        await LoadHistoryAsync();
        _message = rollbackResult.Message ?? string.Empty;
    }

    private async Task LoadHistoryAsync()
    {
        if (string.IsNullOrWhiteSpace(_request.AppName))
        {
            _history = [];
            return;
        }

        _history = (await DeploymentHistoryStore.GetByAppAsync(_request.AppName)).ToList();
    }

    private bool IsLatest(DeploymentHistoryItem item)
        => OrderedHistory.Count > 0 && string.Equals(OrderedHistory[0].DeploymentId, item.DeploymentId, StringComparison.OrdinalIgnoreCase);

    private bool CanRollback(DeploymentHistoryItem item)
    {
        return item.Status == DeploymentStatus.Succeeded
            && !item.IsRollback
            && !string.IsNullOrWhiteSpace(item.BackupPath)
            && !IsLatest(item);
    }
}
