@page "/logs"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@using Microsoft.JSInterop
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject IRuntimeEnvironment RuntimeEnvironment
@inject IFileSystem FileSystem

<PageTitle>Logs</PageTitle>

<div class="page-container logs-page">
    <div class="page-header">
        <div>
            <h1>Logs</h1>
            <p class="page-description">Browse and download operation log files.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="message-area error">
            @_errorMessage
        </div>
    }

    <section class="card logs-shell">
        @if (_isLoading)
        {
            <ActivityIndicator Title="Loading log files" Message="Reading the log folder." />
        }
        else if (_logFiles.Count == 0)
        {
            <p class="page-description">No log files found.</p>
        }
        else
        {
            <div class="logs-toolbar">
                <div class="field logs-retention-field">
                    <span>Delete files older than</span>
                    <input type="date"
                           value="@_deleteOlderThanDateText"
                           disabled="@_isBulkDeleting"
                           @onchange="OnDeleteOlderThanDateChanged"
                           />
                </div>
                <div class="action-group">
                    @if (_confirmingBulkDelete)
                    {
                        <button type="button"
                                class="btn btn-danger"
                                disabled="@_isBulkDeleting"
                                @onclick="DeleteOlderThanAsync">
                            @if (_isBulkDeleting)
                            {
                                <span class="btn-content"><span class="btn-spinner" aria-hidden="true"></span>Deleting</span>
                            }
                            else
                            {
                                <span class="btn-content">Confirm</span>
                            }
                        </button>
                        <button type="button"
                                class="btn btn-secondary"
                                disabled="@_isBulkDeleting"
                                @onclick="CancelBulkDelete">
                            <span class="btn-content">Cancel</span>
                        </button>
                    }
                    else
                    {
                        <button type="button"
                                class="btn btn-danger"
                                disabled="@_isBulkDeleting"
                                @onclick="BeginBulkDelete">
                            <span class="btn-content">Delete older logs</span>
                        </button>
                    }
                </div>
            </div>

            <div class="logs-file-list">
                @foreach (var logFile in _logFiles)
                {
                    var isProcessing = string.Equals(_processingFileName, logFile.Name, StringComparison.OrdinalIgnoreCase);
                    var isConfirmingDelete = string.Equals(_confirmingDeleteFileName, logFile.Name, StringComparison.OrdinalIgnoreCase);

                    <div class="logs-file-item">
                        <div class="logs-file-main">
                            <div class="logs-file-name">@logFile.Name</div>
                            <div class="logs-file-meta">@FormatTimestamp(logFile.LastModifiedUtc)</div>
                        </div>
                        <div class="action-group">
                            <button type="button"
                                    class="btn btn-secondary"
                                    disabled="@isProcessing"
                                    @onclick="() => DownloadAsync(logFile)">
                                @if (IsActiveFileAction(logFile.Name, "Download"))
                                {
                                    <span class="btn-content"><span class="btn-spinner" aria-hidden="true"></span>Downloading</span>
                                }
                                else
                                {
                                    <span class="btn-content">Download</span>
                                }
                            </button>

                            @if (isConfirmingDelete)
                            {
                                <button type="button"
                                        class="btn btn-danger"
                                        disabled="@isProcessing"
                                        @onclick="() => DeleteAsync(logFile)">
                                    @if (IsActiveFileAction(logFile.Name, "Delete"))
                                    {
                                        <span class="btn-content"><span class="btn-spinner" aria-hidden="true"></span>Deleting</span>
                                    }
                                    else
                                    {
                                        <span class="btn-content">Confirm</span>
                                    }
                                </button>
                                <button type="button"
                                        class="btn btn-secondary"
                                        disabled="@isProcessing"
                                        @onclick="CancelDelete">
                                    <span class="btn-content">Cancel</span>
                                </button>
                            }
                            else
                            {
                                <button type="button"
                                        class="btn btn-danger"
                                        disabled="@isProcessing"
                                        @onclick="() => BeginDelete(logFile.Name)">
                                    <span class="btn-content">Delete</span>
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </section>
</div>

@code {
    private readonly List<LogFileItem> _logFiles = new();
    private bool _isLoading = true;
    private string _errorMessage = string.Empty;
    private string _logDirectory = string.Empty;
    private string _processingFileName = string.Empty;
    private string _confirmingDeleteFileName = string.Empty;
    private string _activeFileAction = string.Empty;
    private string _deleteOlderThanDateText = string.Empty;
    private bool _confirmingBulkDelete;
    private bool _isBulkDeleting;

    protected override Task OnInitializedAsync()
    {
        LoadLogFiles();
        return Task.CompletedTask;
    }

    private void LoadLogFiles()
    {
        _isLoading = true;
        _errorMessage = string.Empty;
        _logFiles.Clear();

        try
        {
            _logDirectory = Path.Combine(RuntimeEnvironment.GetAppsRootPath(), "_logs");
            if (!Directory.Exists(_logDirectory))
            {
                return;
            }

            foreach (var path in Directory.GetFiles(_logDirectory, "*.log", SearchOption.TopDirectoryOnly))
            {
                var fileInfo = new FileInfo(path);
                _logFiles.Add(new LogFileItem
                {
                    Name = fileInfo.Name,
                    LastModifiedUtc = fileInfo.LastWriteTimeUtc
                });
            }

            _logFiles.Sort((left, right) => right.LastModifiedUtc.CompareTo(left.LastModifiedUtc));
        }
        catch (Exception ex)
        {
            _errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Unable to load log files."
                : ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task DownloadAsync(LogFileItem logFile)
    {
        _errorMessage = string.Empty;
        _processingFileName = logFile.Name;
        _activeFileAction = "Download";
        await InvokeAsync(StateHasChanged);

        try
        {
            var path = Path.Combine(_logDirectory, logFile.Name);
            if (!File.Exists(path))
            {
                _errorMessage = "Log file was not found.";
                return;
            }

            var content = await File.ReadAllTextAsync(path);
            await JS.InvokeVoidAsync("serverOpsDownloadTextFile", logFile.Name, content);
        }
        catch (Exception ex)
        {
            _errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Unable to download log file."
                : ex.Message;
        }
        finally
        {
            _processingFileName = string.Empty;
            _activeFileAction = string.Empty;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void BeginDelete(string fileName)
    {
        _confirmingDeleteFileName = fileName;
        _errorMessage = string.Empty;
    }

    private void CancelDelete()
    {
        _confirmingDeleteFileName = string.Empty;
    }

    private void BeginBulkDelete()
    {
        _confirmingBulkDelete = true;
        _errorMessage = string.Empty;
    }

    private void CancelBulkDelete()
    {
        _confirmingBulkDelete = false;
    }

    private async Task DeleteAsync(LogFileItem logFile)
    {
        _errorMessage = string.Empty;
        _processingFileName = logFile.Name;
        _activeFileAction = "Delete";
        _confirmingDeleteFileName = string.Empty;
        await InvokeAsync(StateHasChanged);

        try
        {
            var path = Path.Combine(_logDirectory, logFile.Name);
            if (!FileSystem.FileExists(path))
            {
                _errorMessage = "Log file was not found.";
                return;
            }

            FileSystem.DeleteFile(path);
            LoadLogFiles();
        }
        catch (Exception ex)
        {
            _errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Unable to delete log file."
                : ex.Message;
        }
        finally
        {
            _processingFileName = string.Empty;
            _activeFileAction = string.Empty;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task DeleteOlderThanAsync()
    {
        _errorMessage = string.Empty;
        _confirmingBulkDelete = false;
        _isBulkDeleting = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            if (!TryGetDeleteOlderThanDate(out var cutoffLocalDate))
            {
                _errorMessage = "Select a valid date first.";
                return;
            }

            var deletedCount = 0;
            foreach (var logFile in _logFiles.ToList())
            {
                if (logFile.LastModifiedUtc.ToLocalTime().Date >= cutoffLocalDate.Date)
                {
                    continue;
                }

                var path = Path.Combine(_logDirectory, logFile.Name);
                if (!FileSystem.FileExists(path))
                {
                    continue;
                }

                FileSystem.DeleteFile(path);
                deletedCount++;
            }

            LoadLogFiles();
            if (deletedCount == 0)
            {
                _errorMessage = "No log files matched the selected date.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Unable to delete older log files."
                : ex.Message;
        }
        finally
        {
            _isBulkDeleting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string FormatTimestamp(DateTime value)
        => value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");

    private bool IsActiveFileAction(string fileName, string actionName) =>
        string.Equals(_processingFileName, fileName, StringComparison.OrdinalIgnoreCase) &&
        string.Equals(_activeFileAction, actionName, StringComparison.Ordinal);

    private void OnDeleteOlderThanDateChanged(ChangeEventArgs args)
    {
        _deleteOlderThanDateText = args.Value?.ToString() ?? string.Empty;
        StateHasChanged();
    }

    private bool TryGetDeleteOlderThanDate(out DateTime value)
    {
        if (DateTime.TryParseExact(
            _deleteOlderThanDateText,
            "yyyy-MM-dd",
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.None,
            out value))
        {
            return true;
        }

        return DateTime.TryParse(_deleteOlderThanDateText, out value);
    }

    private sealed class LogFileItem
    {
        public string Name { get; init; } = string.Empty;
        public DateTime LastModifiedUtc { get; init; }
    }
}
