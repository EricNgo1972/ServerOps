@page "/logs"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@using Microsoft.JSInterop
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject IRuntimeEnvironment RuntimeEnvironment

<PageTitle>Logs</PageTitle>

<div class="page-container logs-page">
    <div class="page-header">
        <div>
            <h1>Logs</h1>
            <p class="page-description">Browse and download operation log files.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="message-area error">
            @_errorMessage
        </div>
    }

    <section class="card logs-shell">
        @if (_isLoading)
        {
            <ActivityIndicator Title="Loading log files" Message="Reading the log folder." />
        }
        else if (_logFiles.Count == 0)
        {
            <p class="page-description">No log files found.</p>
        }
        else
        {
            <div class="logs-file-list">
                @foreach (var logFile in _logFiles)
                {
                    <button type="button"
                            class="logs-file-item"
                            @onclick="() => DownloadAsync(logFile)">
                        <div class="logs-file-main">
                            <div class="logs-file-name">@logFile.Name</div>
                            <div class="logs-file-meta">@FormatTimestamp(logFile.LastModifiedUtc)</div>
                        </div>
                        <span class="btn btn-secondary">Download</span>
                    </button>
                }
            </div>
        }
    </section>
</div>

@code {
    private readonly List<LogFileItem> _logFiles = new();
    private bool _isLoading = true;
    private string _errorMessage = string.Empty;
    private string _logDirectory = string.Empty;

    protected override Task OnInitializedAsync()
    {
        LoadLogFiles();
        return Task.CompletedTask;
    }

    private void LoadLogFiles()
    {
        _isLoading = true;
        _errorMessage = string.Empty;
        _logFiles.Clear();

        try
        {
            _logDirectory = Path.Combine(RuntimeEnvironment.GetAppsRootPath(), "_logs");
            if (!Directory.Exists(_logDirectory))
            {
                return;
            }

            foreach (var path in Directory.GetFiles(_logDirectory, "*.log", SearchOption.TopDirectoryOnly))
            {
                var fileInfo = new FileInfo(path);
                _logFiles.Add(new LogFileItem
                {
                    Name = fileInfo.Name,
                    LastModifiedUtc = fileInfo.LastWriteTimeUtc
                });
            }

            _logFiles.Sort((left, right) => right.LastModifiedUtc.CompareTo(left.LastModifiedUtc));
        }
        catch (Exception ex)
        {
            _errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Unable to load log files."
                : ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task DownloadAsync(LogFileItem logFile)
    {
        _errorMessage = string.Empty;

        try
        {
            var path = Path.Combine(_logDirectory, logFile.Name);
            if (!File.Exists(path))
            {
                _errorMessage = "Log file was not found.";
                return;
            }

            var content = await File.ReadAllTextAsync(path);
            await JS.InvokeVoidAsync("serverOpsDownloadTextFile", logFile.Name, content);
        }
        catch (Exception ex)
        {
            _errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Unable to download log file."
                : ex.Message;
        }
    }

    private static string FormatTimestamp(DateTime value)
        => value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");

    private sealed class LogFileItem
    {
        public string Name { get; init; } = string.Empty;
        public DateTime LastModifiedUtc { get; init; }
    }
}
