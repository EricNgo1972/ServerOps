@page "/applications"
@attribute [Authorize]
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@using ServerOps.Domain.Entities
@using ServerOps.Domain.Enums
@rendermode InteractiveServer
@inject IAppCatalogService AppCatalogService
@inject IServiceControlService ServiceControlService
@inject IAppRemovalService AppRemovalService
@inject IEndpointRegistry EndpointRegistry
@inject ServerOps.Web.Services.LiveOperationLogState LiveOperationLogState

<PageTitle>Applications</PageTitle>

<div class="page-container">
    <div class="page-header">
        <div>
            <h1>Applications</h1>
            <p class="page-description">Installed and running apps on this host.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="message-area @(_isError ? "error" : "success")">
            @_message
        </div>
    }

    <section class="card applications-shell">
        @if (_isLoading)
        {
            <ActivityIndicator Title="Loading applications" Message="Fetching managed application status." />
        }
        else if (_apps.Count == 0)
        {
            <p class="page-description">No managed applications found.</p>
        }
        else
        {
            <div class="app-list">
                @foreach (var app in _apps)
                {
                    var rowId = GetRowId(app);
                    var isProcessing = string.Equals(_processingAppId, rowId, StringComparison.Ordinal);
                    var isConfirmingRemoval = string.Equals(_confirmingRemovalAppId, rowId, StringComparison.Ordinal);

                    <article class="app-row-card">
                        <div class="app-row-main">
                            <div class="app-identity">
                                <h2 class="app-title">@GetAppName(app)</h2>
                                <div class="app-meta">@app.ServiceName</div>
                            </div>

                            <div class="app-runtime">
                                <div class="app-runtime-item">
                                    <span class="runtime-label">Status</span>
                                    <span class="app-badge @GetStatusCssClass(app.Status)">@app.Status</span>
                                </div>
                                <div class="app-runtime-item">
                                    <span class="runtime-label">Port</span>
                                    <span class="runtime-value">@GetPortText(app)</span>
                                </div>
                                <div class="app-runtime-item">
                                    <span class="runtime-label">Local URL</span>
                                    @if (GetLocalUrl(app) is { Length: > 0 } localUrl)
                                    {
                                        <a class="app-local-link"
                                           href="@localUrl"
                                           target="_blank"
                                           rel="noopener noreferrer">
                                            @localUrl
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="runtime-value">-</span>
                                    }
                                </div>
                            </div>

                            <div class="action-group">
                                @if (app.Status == ServiceStatus.Stopped)
                                {
                                    <button type="button"
                                            class="btn btn-secondary"
                                            disabled="@isProcessing"
                                            @onclick="() => ExecuteActionAsync(app, ServiceAction.Start)">
                                        @if (IsAppActionActive(app, "Start"))
                                        {
                                            <span class="btn-content"><span class="btn-spinner" aria-hidden="true"></span>Starting</span>
                                        }
                                        else
                                        {
                                            <span class="btn-content">Start</span>
                                        }
                                    </button>
                                }
                                else if (app.Status == ServiceStatus.Running)
                                {
                                    <button type="button"
                                            class="btn btn-secondary"
                                            disabled="@isProcessing"
                                            @onclick="() => ExecuteActionAsync(app, ServiceAction.Stop)">
                                        @if (IsAppActionActive(app, "Stop"))
                                        {
                                            <span class="btn-content"><span class="btn-spinner" aria-hidden="true"></span>Stopping</span>
                                        }
                                        else
                                        {
                                            <span class="btn-content">Stop</span>
                                        }
                                    </button>
                                }

                                <button type="button"
                                        class="btn btn-primary"
                                        disabled="@isProcessing"
                                        @onclick="() => ExecuteActionAsync(app, ServiceAction.Restart)">
                                    @if (IsAppActionActive(app, "Restart"))
                                    {
                                        <span class="btn-content"><span class="btn-spinner" aria-hidden="true"></span>Restarting</span>
                                    }
                                    else
                                    {
                                        <span class="btn-content">Restart</span>
                                    }
                                </button>

                                @if (isConfirmingRemoval)
                                {
                                    <div class="inline-confirm">
                                        <span class="inline-confirm-text">Remove?</span>
                                        <button type="button"
                                                class="btn btn-danger"
                                                disabled="@isProcessing"
                                                @onclick="() => RemoveAppAsync(app)">
                                            @if (IsAppActionActive(app, "Remove"))
                                            {
                                                <span class="btn-content"><span class="btn-spinner" aria-hidden="true"></span>Removing</span>
                                            }
                                            else
                                            {
                                                <span class="btn-content">Confirm</span>
                                            }
                                        </button>
                                        <button type="button"
                                                class="btn btn-secondary"
                                                disabled="@isProcessing"
                                                @onclick="CancelRemoval">
                                            <span class="btn-content">Cancel</span>
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <button type="button"
                                            class="btn btn-danger"
                                            disabled="@isProcessing"
                                            @onclick="() => BeginRemoval(rowId)">
                                        <span class="btn-content">Remove</span>
                                    </button>
                                }
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</div>

@code {
    private IReadOnlyList<AppInstance> _apps = Array.Empty<AppInstance>();
    private IReadOnlyList<ServerOps.Application.Models.EndpointMapping> _mappings = Array.Empty<ServerOps.Application.Models.EndpointMapping>();
    private bool _isLoading = true;
    private string _processingAppId = string.Empty;
    private string _confirmingRemovalAppId = string.Empty;
    private string _activeAction = string.Empty;
    private string _message = string.Empty;
    private bool _isError;

    protected override async Task OnInitializedAsync()
    {
        await LoadAppsAsync();
    }

    private async Task LoadAppsAsync()
    {
        _isLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var appsTask = AppCatalogService.GetApplicationsAsync();
            var mappingsTask = EndpointRegistry.GetMappingsAsync();
            await Task.WhenAll(appsTask, mappingsTask);
            _apps = await appsTask;
            _mappings = await mappingsTask;
        }
        catch (Exception ex)
        {
            _apps = Array.Empty<AppInstance>();
            _mappings = Array.Empty<ServerOps.Application.Models.EndpointMapping>();
            _message = string.IsNullOrWhiteSpace(ex.Message)
                ? "Unable to load applications."
                : ex.Message;
            _isError = true;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ExecuteActionAsync(AppInstance app, ServiceAction action)
    {
        var rowId = GetRowId(app);
        if (string.Equals(_processingAppId, rowId, StringComparison.Ordinal))
        {
            return;
        }

        _processingAppId = rowId;
        _confirmingRemovalAppId = string.Empty;
        _activeAction = action.ToString();
        _message = string.Empty;
        _isError = false;
        StateHasChanged();
        var effectiveAction = action == ServiceAction.Restart && app.Status == ServiceStatus.Stopped
            ? ServiceAction.Start
            : action;

        try
        {
            var operationId = Guid.NewGuid().ToString("N");
            LiveOperationLogState.Open(operationId, $"{effectiveAction} {app.ServiceName}");

            var result = action switch
            {
                ServiceAction.Start => await ServiceControlService.StartAsync(app.ServiceName, operationId),
                ServiceAction.Stop => await ServiceControlService.StopAsync(app.ServiceName, operationId),
                ServiceAction.Restart when effectiveAction == ServiceAction.Start => await ServiceControlService.StartAsync(app.ServiceName, operationId),
                _ => await ServiceControlService.RestartAsync(app.ServiceName, operationId)
            };

            _message = BuildResultMessage(app, effectiveAction, result);
            _isError = !result.Succeeded;
        }
        catch (Exception ex)
        {
            _message = string.IsNullOrWhiteSpace(ex.Message)
                ? $"Unable to {action.ToString().ToLowerInvariant()} {GetAppName(app)}."
                : ex.Message;
            _isError = true;
        }
        finally
        {
            _processingAppId = string.Empty;
            _activeAction = string.Empty;
            if (!_isError && effectiveAction is ServiceAction.Start or ServiceAction.Restart)
            {
                await Task.Delay(1500);
            }

            await LoadAppsAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private void BeginRemoval(string rowId)
    {
        var app = _apps.FirstOrDefault(candidate => string.Equals(GetRowId(candidate), rowId, StringComparison.Ordinal));
        if (app is not null && IsAppExposed(app))
        {
            _confirmingRemovalAppId = string.Empty;
            _message = $"Un-expose {GetAppName(app)} first before removing it.";
            _isError = true;
            StateHasChanged();
            return;
        }

        _confirmingRemovalAppId = rowId;
        _message = string.Empty;
        _isError = false;
    }

    private void CancelRemoval()
    {
        _confirmingRemovalAppId = string.Empty;
    }

    private async Task RemoveAppAsync(AppInstance app)
    {
        if (IsAppExposed(app))
        {
            _confirmingRemovalAppId = string.Empty;
            _message = $"Un-expose {GetAppName(app)} first before removing it.";
            _isError = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        var rowId = GetRowId(app);
        if (string.Equals(_processingAppId, rowId, StringComparison.Ordinal))
        {
            return;
        }

        _processingAppId = rowId;
        _confirmingRemovalAppId = string.Empty;
        _activeAction = "Remove";
        _message = string.Empty;
        _isError = false;
        await InvokeAsync(StateHasChanged);

        try
        {
            var operationId = Guid.NewGuid().ToString("N");
            LiveOperationLogState.Open(operationId, $"Remove {app.ServiceName}");
            var result = await AppRemovalService.RemoveAsync(app.ServiceName, operationId);
            _message = BuildRemovalMessage(app, result);
            _isError = !result.Succeeded;
        }
        catch (Exception ex)
        {
            _message = string.IsNullOrWhiteSpace(ex.Message)
                ? $"Unable to remove {GetAppName(app)}."
                : ex.Message;
            _isError = true;
        }
        finally
        {
            _processingAppId = string.Empty;
            _activeAction = string.Empty;
            
            await LoadAppsAsync();

            StateHasChanged();
        }
    }

    private static string GetRowId(AppInstance app) =>
        string.IsNullOrWhiteSpace(app.Id) ? app.ServiceName : app.Id;

    private static string GetAppName(AppInstance app) =>
        string.IsNullOrWhiteSpace(app.DisplayName) ? app.ServiceName : app.DisplayName;

    private static string GetPortText(AppInstance app) =>
        app.Ports.Count == 0 ? "-" : app.Ports[0].ToString();

    private static string? GetLocalUrl(AppInstance app) =>
        app.Ports.Count == 0 || app.Ports[0] <= 0
            ? null
            : $"http://localhost:{app.Ports[0]}";

    private static string GetStatusCssClass(ServiceStatus status) =>
        status switch
        {
            ServiceStatus.Running => "running",
            ServiceStatus.Stopped => "stopped",
            ServiceStatus.Failed => "failed",
            _ => "unknown"
        };

    private static string BuildResultMessage(AppInstance app, ServiceAction action, ServerOps.Application.DTOs.CommandResult result)
    {
        var prefix = $"{GetAppName(app)} {GetActionPastTense(action)}";
        var details = string.IsNullOrWhiteSpace(result.StdErr) ? result.StdOut : result.StdErr;

        if (result.Succeeded)
        {
            return $"{prefix} successfully.";
        }

        var cleanedDetails = GetFirstMeaningfulLine(details);
        return string.IsNullOrWhiteSpace(cleanedDetails) ? $"{prefix} failed." : $"{prefix} failed. {cleanedDetails}";
    }

    private static string BuildRemovalMessage(AppInstance app, ServerOps.Application.DTOs.CommandResult result)
    {
        if (result.Succeeded)
        {
            return $"{GetAppName(app)} removed successfully.";
        }

        var cleanedDetails = GetFirstMeaningfulLine(string.IsNullOrWhiteSpace(result.StdErr) ? result.StdOut : result.StdErr);
        return string.IsNullOrWhiteSpace(cleanedDetails)
            ? $"{GetAppName(app)} removal failed."
            : $"{GetAppName(app)} removal failed. {cleanedDetails}";
    }

    private static string GetActionPastTense(ServiceAction action) =>
        action switch
        {
            ServiceAction.Start => "started",
            ServiceAction.Stop => "stopped",
            _ => "restarted"
        };

    private bool IsAppActionActive(AppInstance app, string actionName) =>
        string.Equals(_processingAppId, GetRowId(app), StringComparison.Ordinal) &&
        string.Equals(_activeAction, actionName, StringComparison.Ordinal);

    private bool IsAppExposed(AppInstance app) => FindMapping(app.ServiceName) is not null;

    private ServerOps.Application.Models.EndpointMapping? FindMapping(string? serviceName)
    {
        var normalizedServiceName = NormalizeServiceName(serviceName);
        if (string.IsNullOrWhiteSpace(normalizedServiceName) || _mappings.Count == 0)
        {
            return null;
        }

        return _mappings
            .Where(mapping => !string.IsNullOrWhiteSpace(mapping.ServiceName) && !string.IsNullOrWhiteSpace(mapping.Hostname))
            .OrderByDescending(mapping => NormalizeServiceName(mapping.ServiceName).Length)
            .FirstOrDefault(mapping => NamesMatch(normalizedServiceName, NormalizeServiceName(mapping.ServiceName)));
    }

    private static bool NamesMatch(string left, string right)
    {
        if (string.Equals(left, right, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        return left.StartsWith(right + "-", StringComparison.OrdinalIgnoreCase) ||
               left.StartsWith(right + ".", StringComparison.OrdinalIgnoreCase) ||
               right.StartsWith(left + "-", StringComparison.OrdinalIgnoreCase) ||
               right.StartsWith(left + ".", StringComparison.OrdinalIgnoreCase);
    }

    private static string NormalizeServiceName(string? serviceName)
    {
        return (serviceName ?? string.Empty)
            .Replace(".service", "", StringComparison.OrdinalIgnoreCase)
            .Trim()
            .ToLowerInvariant();
    }

    private static string GetFirstMeaningfulLine(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return value
            .ReplaceLineEndings("\n")
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .FirstOrDefault(line => !line.StartsWith("SERVICE_NAME", StringComparison.OrdinalIgnoreCase))
            ?? string.Empty;
    }

    private enum ServiceAction
    {
        Start,
        Stop,
        Restart
    }

}
