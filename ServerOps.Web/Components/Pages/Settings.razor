@page "/settings"
@attribute [Authorize]
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@using System.Text.Json
@using System.Text.Json.Nodes
@using Microsoft.JSInterop
@using ServerOps.Domain.Enums
@rendermode InteractiveServer
@inject IConfiguration Configuration
@inject IWebHostEnvironment HostEnvironment
@inject IRuntimeEnvironment RuntimeEnvironment
@inject IHostService HostService
@inject ICommandRunner CommandRunner
@inject ICloudflaredService CloudflaredService
@inject IOperationLogger OperationLogger
@inject IServiceControlService ServiceControlService
@inject IJSRuntime JS
@inject ServerOps.Web.Services.LiveOperationLogState LiveOperationLogState

<PageTitle>Settings</PageTitle>

<div class="page-container">
    <div class="page-header">
        <div>
            <h1>Settings</h1>
            <p class="page-description">View platform configuration.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="message-area success">
            @_successMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="message-area error">
            @_errorMessage
        </div>
    }

    @if (_isLoading)
    {
        <section class="card">
            <ActivityIndicator Title="Loading settings" Message="Fetching environment paths, defaults, and system setup status." />
        </section>
    }
    else
    {
        <section class="card">
            <div class="page-header">
                <div>
                    <h2>Environment</h2>
                    <p class="page-description">Runtime paths used by ServerOps.</p>
                </div>
            </div>

            <div class="status-list">
                <div>
                    <dt>Apps root path</dt>
                    <dd>@_appsRootPath</dd>
                </div>
                <div>
                    <dt>Cloudflared config path</dt>
                    <dd>@_cloudflaredConfigPath</dd>
                </div>
            </div>
        </section>

        <section class="card">
            <div class="page-header">
                <div>
                    <h2>Domain</h2>
                    <p class="page-description">Used to generate application URLs.</p>
                </div>
            </div>

            <div class="field">
                <span>Base domain</span>
                <input value="@_baseDomain"
                       disabled="@_isSaving || !string.IsNullOrWhiteSpace(_processingComponent)"
                       @oninput="OnBaseDomainChanged" />
            </div>

            <p class="page-description">Example: @GetDomainExample()</p>

            <div class="button-row">
                <button type="button"
                        class="btn btn-primary"
                        disabled="@_isSaving || !string.IsNullOrWhiteSpace(_processingComponent)"
                        @onclick="SaveAsync">
                    @(_isSaving ? "Saving..." : "Save")
                </button>
            </div>
        </section>

        <section class="card">
            <div class="page-header">
                <div>
                    <h2>System Setup</h2>
                    <p class="page-description">Install required host components.</p>
                </div>
            </div>

            <div class="settings-setup-list">
                @foreach (var component in _components)
                {
                    var status = _componentStatuses.TryGetValue(component.Key, out var existingStatus)
                        ? existingStatus
                        : SetupStatus.NotInstalled;
                    var serviceStatus = _componentServiceStatuses.TryGetValue(component.Key, out var existingServiceStatus)
                        ? existingServiceStatus
                        : ServiceStatus.Unknown;
                    var isProcessing = string.Equals(_processingComponent, component.Key, StringComparison.Ordinal);

                    <div class="settings-setup-row">
                        <div class="settings-setup-name">@component.DisplayName</div>
                        <div>
                            <span class="app-badge @GetSetupBadgeClass(status, isProcessing, component.Key)">
                                @GetSetupLabel(status, isProcessing, component.Key)
                            </span>
                        </div>
                        <div class="action-group">
                            @if (isProcessing)
                            {
                                <button type="button"
                                        class="btn btn-secondary"
                                        @onclick="CancelProcessingAsync">
                                    Cancel
                                </button>
                            }
                            else if (component.Key == "cloudflared" && status == SetupStatus.Installed && _cloudflaredTunnelInfo.IsConfigured && !_cloudflaredTunnelInfo.IsServiceInstalled)
                            {
                                <button type="button"
                                        class="btn btn-secondary"
                                        disabled="@(!string.IsNullOrWhiteSpace(_processingComponent))"
                                        @onclick="() => CreateCloudflaredServiceAsync(component)">
                                    Create Service
                                </button>
                            }
                            else if (status == SetupStatus.Installed && serviceStatus != ServiceStatus.Unknown)
                            {
                                @if (serviceStatus == ServiceStatus.Running)
                                {
                                    <button type="button"
                                            class="btn btn-secondary"
                                            disabled="@(!string.IsNullOrWhiteSpace(_processingComponent))"
                                            @onclick='() => ChangeServiceStateAsync(component, "stop")'>
                                        Stop
                                    </button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="btn btn-secondary"
                                            disabled="@(!string.IsNullOrWhiteSpace(_processingComponent))"
                                            @onclick='() => ChangeServiceStateAsync(component, "start")'>
                                        Start
                                    </button>
                                }
                            }
                            else if (status != SetupStatus.Installed)
                            {
                                <button type="button"
                                        class="btn btn-secondary"
                                        disabled="@(!string.IsNullOrWhiteSpace(_processingComponent))"
                                        @onclick="() => InstallComponentAsync(component)">
                                    Install
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        </section>
    }
</div>

<LiveOperationLogDrawer />

@code {
    private readonly IReadOnlyList<SetupComponent> _components =
    [
        new("cloudflared", "Cloudflared", ["cloudflared"]),
        new("postgresql", "PostgreSQL", ["postgresql", "postgres"])
    ];

    private readonly Dictionary<string, SetupStatus> _componentStatuses = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, ServiceStatus> _componentServiceStatuses = new(StringComparer.OrdinalIgnoreCase);
    private TunnelInfo _cloudflaredTunnelInfo = new();
    private string _appsRootPath = string.Empty;
    private string _cloudflaredConfigPath = string.Empty;
    private string _baseDomain = string.Empty;
    private bool _isLoading = true;
    private bool _isSaving;
    private string _processingComponent = string.Empty;
    private string _processingAction = string.Empty;
    private CancellationTokenSource? _processingCancellationTokenSource;
    private string _successMessage = string.Empty;
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _appsRootPath = RuntimeEnvironment.GetAppsRootPath();
        _cloudflaredConfigPath = RuntimeEnvironment.GetCloudflaredConfigPath();
        _baseDomain = (Configuration["Domain:DefaultDomainSuffix"] ?? string.Empty).Trim();
        await LoadComponentStatusesAsync();
        _isLoading = false;
    }

    private async Task LoadComponentStatusesAsync()
    {
        _componentStatuses.Clear();
        _componentServiceStatuses.Clear();
        var services = await HostService.GetServicesAsync();
        _cloudflaredTunnelInfo = await CloudflaredService.GetTunnelInfoAsync();

        foreach (var component in _components)
        {
            _componentStatuses[component.Key] = component.Key switch
            {
                "cloudflared" => await IsCloudflaredInstalledAsync(),
                "postgresql" => IsServiceInstalled(services, "postgresql", "postgres") ? SetupStatus.Installed : SetupStatus.NotInstalled,
                _ => SetupStatus.NotInstalled
            };

            _componentServiceStatuses[component.Key] = ResolveServiceStatus(services, component.ServiceAliases);
        }
    }

    private async Task<SetupStatus> IsCloudflaredInstalledAsync()
    {
        var candidateCommands = RuntimeEnvironment.GetCurrentOs() switch
        {
            OsType.Windows => new[]
            {
                "cloudflared",
                @"C:\Cloudflared\bin\cloudflared.exe"
            },
            _ => new[] { "cloudflared" }
        };

        foreach (var command in candidateCommands)
        {
            try
            {
                if (Path.IsPathRooted(command) && !File.Exists(command))
                {
                    continue;
                }

                var result = await CommandRunner.RunAsync(new CommandRequest
                {
                    Command = command,
                    Arguments = ["--version"]
                });

                if (result.Succeeded)
                {
                    return SetupStatus.Installed;
                }
            }
            catch
            {
            }
        }

        return SetupStatus.NotInstalled;
    }

    private static bool IsServiceInstalled(IReadOnlyList<ServerOps.Domain.Entities.ServiceInfo> services, params string[] aliases)
    {
        return services.Any(service =>
            aliases.Any(alias => MatchesServiceAlias(service.Name, alias)));
    }

    private static ServiceStatus ResolveServiceStatus(IReadOnlyList<ServerOps.Domain.Entities.ServiceInfo> services, IReadOnlyList<string> aliases)
    {
        var service = services.FirstOrDefault(service =>
            aliases.Any(alias => MatchesServiceAlias(service.Name, alias)));

        return service?.Status ?? ServiceStatus.Unknown;
    }

    private static bool MatchesServiceAlias(string serviceName, string alias)
    {
        return string.Equals(serviceName, alias, StringComparison.OrdinalIgnoreCase) ||
               string.Equals(serviceName, $"{alias}.service", StringComparison.OrdinalIgnoreCase) ||
               serviceName.StartsWith(alias + "-", StringComparison.OrdinalIgnoreCase) ||
               serviceName.StartsWith(alias + "@", StringComparison.OrdinalIgnoreCase);
    }

    private void OnBaseDomainChanged(ChangeEventArgs args)
    {
        _baseDomain = args.Value?.ToString()?.Trim() ?? string.Empty;
    }

    private async Task SaveAsync()
    {
        if (_isSaving)
        {
            return;
        }

        _isSaving = true;
        _successMessage = string.Empty;
        _errorMessage = string.Empty;
        await InvokeAsync(StateHasChanged);

        try
        {
            var appSettingsPath = Path.Combine(HostEnvironment.ContentRootPath, "appsettings.json");
            if (!File.Exists(appSettingsPath))
            {
                throw new InvalidOperationException("appsettings.json was not found.");
            }

            var content = await File.ReadAllTextAsync(appSettingsPath);
            var rootNode = string.IsNullOrWhiteSpace(content)
                ? new JsonObject()
                : JsonNode.Parse(content) as JsonObject ?? new JsonObject();

            var domainSection = rootNode["Domain"] as JsonObject ?? new JsonObject();
            domainSection["DefaultDomainSuffix"] = _baseDomain;
            rootNode["Domain"] = domainSection;

            var updatedContent = rootNode.ToJsonString(new JsonSerializerOptions
            {
                WriteIndented = true
            });

            await File.WriteAllTextAsync(appSettingsPath, updatedContent);
            _successMessage = "Base domain saved successfully.";
        }
        catch (Exception ex)
        {
            _errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Unable to save the base domain."
                : ex.Message;
        }
        finally
        {
            _isSaving = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task InstallComponentAsync(SetupComponent component)
    {
        if (!string.IsNullOrWhiteSpace(_processingComponent))
        {
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Install {component.DisplayName}?");
        if (!confirmed)
        {
            return;
        }

        _processingAction = "install";
        _processingComponent = component.Key;
        _componentStatuses[component.Key] = SetupStatus.Installing;
        _errorMessage = string.Empty;
        _processingCancellationTokenSource = new CancellationTokenSource();
        await InvokeAsync(StateHasChanged);

        try
        {
            var operationId = Guid.NewGuid().ToString("N");
            LiveOperationLogState.Open(operationId, $"Install {component.DisplayName}");
            await OperationLogger.LogAsync(operationId, "SystemSetup", $"Install started component={component.DisplayName}");
            using var progressCancellationTokenSource = new CancellationTokenSource();
            var progressTask = RunProgressHeartbeatAsync(operationId, "Install", component.DisplayName, progressCancellationTokenSource.Token);

            try
            {
                var result = await RunInstallAsync(component.Key, operationId, _processingCancellationTokenSource.Token);
                await LogCommandResultAsync(operationId, component.DisplayName, result);

                if (!result.Succeeded)
                {
                    var details = GetPrimaryCommandMessage(result);
                    throw new InvalidOperationException(string.IsNullOrWhiteSpace(details)
                        ? $"Unable to install {component.DisplayName}."
                        : details.Trim());
                }

                await LoadComponentStatusesAsync();
            }
            finally
            {
                progressCancellationTokenSource.Cancel();
                await IgnoreCancellationAsync(progressTask);
            }
        }
        catch (OperationCanceledException)
        {
            await OperationLogger.LogAsync(LiveOperationLogState.OperationId, "SystemSetup", $"Install cancelled component={component.DisplayName}");
            await LoadComponentStatusesAsync();
        }
        catch (Exception ex)
        {
            _componentStatuses[component.Key] = SetupStatus.NotInstalled;
            _errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? $"Unable to install {component.DisplayName}."
                : ex.Message;
        }
        finally
        {
            _processingCancellationTokenSource?.Dispose();
            _processingCancellationTokenSource = null;
            _processingAction = string.Empty;
            _processingComponent = string.Empty;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ChangeServiceStateAsync(SetupComponent component, string action)
    {
        if (!string.IsNullOrWhiteSpace(_processingComponent))
        {
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", $"{action.ToUpperInvariant()} {component.DisplayName}?");
        if (!confirmed)
        {
            return;
        }

        _processingAction = action;
        _processingComponent = component.Key;
        _errorMessage = string.Empty;
        _processingCancellationTokenSource = new CancellationTokenSource();
        await InvokeAsync(StateHasChanged);

        try
        {
            var operationId = Guid.NewGuid().ToString("N");
            var title = $"{(action == "stop" ? "Stop" : "Start")} {component.DisplayName}";
            LiveOperationLogState.Open(operationId, title);
            await OperationLogger.LogAsync(operationId, "SystemSetup", $"{title} requested");

            var serviceName = component.ServiceAliases.FirstOrDefault() ?? component.Key;
            var result = action == "stop"
                ? await ServiceControlService.StopAsync(serviceName, operationId, _processingCancellationTokenSource.Token)
                : await ServiceControlService.StartAsync(serviceName, operationId, _processingCancellationTokenSource.Token);

            if (!result.Succeeded)
            {
                var details = GetPrimaryCommandMessage(result);
                throw new InvalidOperationException(string.IsNullOrWhiteSpace(details)
                    ? $"Unable to {action} {component.DisplayName}."
                    : details.Trim());
            }

            await LoadComponentStatusesAsync();
        }
        catch (OperationCanceledException)
        {
            await OperationLogger.LogAsync(LiveOperationLogState.OperationId, "SystemSetup", $"{component.DisplayName} {action} cancelled");
            await LoadComponentStatusesAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? $"Unable to {action} {component.DisplayName}."
                : ex.Message;
        }
        finally
        {
            _processingCancellationTokenSource?.Dispose();
            _processingCancellationTokenSource = null;
            _processingAction = string.Empty;
            _processingComponent = string.Empty;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task CreateCloudflaredServiceAsync(SetupComponent component)
    {
        if (!string.IsNullOrWhiteSpace(_processingComponent))
        {
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Create {component.DisplayName} service?");
        if (!confirmed)
        {
            return;
        }

        _processingAction = "create-service";
        _processingComponent = component.Key;
        _errorMessage = string.Empty;
        _processingCancellationTokenSource = new CancellationTokenSource();
        await InvokeAsync(StateHasChanged);

        try
        {
            var operationId = Guid.NewGuid().ToString("N");
            LiveOperationLogState.Open(operationId, $"Create {component.DisplayName} Service");
            await OperationLogger.LogAsync(operationId, "SystemSetup", $"Create service requested component={component.DisplayName}");

            var result = await CloudflaredService.StartAsync(operationId, _processingCancellationTokenSource.Token);
            if (!result.Succeeded)
            {
                var details = GetPrimaryCommandMessage(result);
                throw new InvalidOperationException(string.IsNullOrWhiteSpace(details)
                    ? $"Unable to create {component.DisplayName} service."
                    : details.Trim());
            }

            await LoadComponentStatusesAsync();
        }
        catch (OperationCanceledException)
        {
            await OperationLogger.LogAsync(LiveOperationLogState.OperationId, "SystemSetup", $"{component.DisplayName} service creation cancelled");
            await LoadComponentStatusesAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? $"Unable to create {component.DisplayName} service."
                : ex.Message;
        }
        finally
        {
            _processingCancellationTokenSource?.Dispose();
            _processingCancellationTokenSource = null;
            _processingAction = string.Empty;
            _processingComponent = string.Empty;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task CancelProcessingAsync()
    {
        if (_processingCancellationTokenSource is null || string.IsNullOrWhiteSpace(_processingComponent))
        {
            return;
        }

        _processingCancellationTokenSource.Cancel();
        await InvokeAsync(StateHasChanged);
    }

    private Task<CommandResult> RunInstallAsync(string componentKey, string operationId, CancellationToken cancellationToken)
    {
        return RuntimeEnvironment.GetCurrentOs() switch
        {
            OsType.Windows => RunWindowsInstallAsync(componentKey, operationId, cancellationToken),
            OsType.Linux => RunLinuxInstallAsync(componentKey, operationId, cancellationToken),
            _ => Task.FromResult(new CommandResult { ExitCode = -1, StdErr = "Unsupported operating system." })
        };
    }

    private Task<CommandResult> RunWindowsInstallAsync(string componentKey, string operationId, CancellationToken cancellationToken)
    {
        return componentKey switch
        {
            "cloudflared" => RunLoggedCommandAsync(
                operationId,
                "winget install Cloudflare.cloudflared",
                CreateStreamingCommandRequest(
                "winget",
                operationId,
                [
                    "install",
                    "--id", "Cloudflare.cloudflared",
                    "--exact",
                    "--silent",
                    "--disable-interactivity",
                    "--accept-package-agreements",
                    "--accept-source-agreements"
                ], cancellationToken), cancellationToken),
            "ssh" => RunLoggedCommandAsync(
                operationId,
                "Add-WindowsCapability OpenSSH.Server",
                CreateStreamingCommandRequest(
                "powershell",
                operationId,
                [
                    "-NoProfile",
                    "-NonInteractive",
                    "-Command",
                    "Add-WindowsCapability -Online -Name OpenSSH.Server~~~~0.0.1.0"
                ], cancellationToken), cancellationToken),
            "postgresql" => RunWindowsPostgreSqlInstallAsync(operationId, cancellationToken),
            _ => Task.FromResult(new CommandResult { ExitCode = -1, StdErr = "Unknown component." })
        };
    }

    private async Task<CommandResult> RunWindowsPostgreSqlInstallAsync(string operationId, CancellationToken cancellationToken)
    {
        var packageIds = new[]
        {
            "PostgreSQL.PostgreSQL.17",
            "PostgreSQL.PostgreSQL.16",
            "PostgreSQL.PostgreSQL.15"
        };

        foreach (var packageId in packageIds)
        {
            await OperationLogger.LogAsync(operationId, "SystemSetup", $"Trying winget package id {packageId}");

            var result = await RunLoggedCommandAsync(
                operationId,
                $"winget install {packageId}",
                CreateStreamingCommandRequest(
                "winget",
                operationId,
                [
                    "install",
                    "--id", packageId,
                    "--exact",
                    "--silent",
                    "--disable-interactivity",
                    "--accept-package-agreements",
                    "--accept-source-agreements"
                ], cancellationToken), cancellationToken);

            if (result.Succeeded)
            {
                return result;
            }

            if (!ContainsNoPackageFound(result))
            {
                return result;
            }
        }

        return new CommandResult
        {
            ExitCode = -1,
            StdErr = "No PostgreSQL package was found in winget. Tried PostgreSQL.PostgreSQL.17, PostgreSQL.PostgreSQL.16, and PostgreSQL.PostgreSQL.15."
        };
    }

    private Task<CommandResult> RunLinuxInstallAsync(string componentKey, string operationId, CancellationToken cancellationToken)
    {
        return componentKey switch
        {
            "cloudflared" => RunLoggedCommandAsync(operationId, "apt-get install cloudflared", CreateStreamingCommandRequest("apt-get", operationId, ["install", "-y", "cloudflared"], cancellationToken), cancellationToken),
            "ssh" => RunLoggedCommandAsync(operationId, "apt-get install openssh-server", CreateStreamingCommandRequest("apt-get", operationId, ["install", "-y", "openssh-server"], cancellationToken), cancellationToken),
            "postgresql" => RunLoggedCommandAsync(operationId, "apt-get install postgresql", CreateStreamingCommandRequest("apt-get", operationId, ["install", "-y", "postgresql"], cancellationToken), cancellationToken),
            _ => Task.FromResult(new CommandResult { ExitCode = -1, StdErr = "Unknown component." })
        };
    }

    private string GetDomainExample()
    {
        return string.IsNullOrWhiteSpace(_baseDomain)
            ? "app.example.com"
            : $"app.{_baseDomain}";
    }

    private string GetSetupLabel(SetupStatus status, bool isProcessing, string componentKey)
    {
        if (_componentServiceStatuses.TryGetValue(componentKey, out var serviceStatus) &&
            status == SetupStatus.Installed &&
            !isProcessing)
        {
            return serviceStatus switch
            {
                ServiceStatus.Running => "Running",
                ServiceStatus.Stopped => "Stopped",
                ServiceStatus.Failed => "Failed",
                _ => "Installed"
            };
        }

        return isProcessing
            ? _processingAction switch
            {
                "start" => "Starting",
                "stop" => "Stopping",
                "create-service" => "Creating Service",
                _ => "Installing"
            }
            : status == SetupStatus.Installed
                ? "Installed"
                : "Not Installed";
    }

    private string GetSetupBadgeClass(SetupStatus status, bool isProcessing, string componentKey)
    {
        if (_componentServiceStatuses.TryGetValue(componentKey, out var serviceStatus) &&
            status == SetupStatus.Installed &&
            !isProcessing)
        {
            return serviceStatus switch
            {
                ServiceStatus.Running => "running",
                ServiceStatus.Stopped => "stopped",
                ServiceStatus.Failed => "failed",
                _ => "unknown"
            };
        }

        return isProcessing && _processingComponent == componentKey
            ? "unknown"
            : status == SetupStatus.Installed
                ? "unknown"
                : "stopped";
    }

    private async Task LogCommandResultAsync(string operationId, string componentName, CommandResult result, string action = "Install")
    {
        var outputLines = ExtractMeaningfulLines(result.StdOut, result.StdErr);
        foreach (var line in outputLines)
        {
            await OperationLogger.LogAsync(operationId, "SystemSetup", line);
        }

        var summary = result.Succeeded
            ? $"{action} completed component={componentName}, exitCode={result.ExitCode}"
            : $"{action} failed component={componentName}, exitCode={result.ExitCode}";

        await OperationLogger.LogAsync(operationId, "SystemSetup", summary);
    }

    private static string GetPrimaryCommandMessage(CommandResult result)
    {
        var lines = ExtractMeaningfulLines(result.StdOut, result.StdErr);
        return lines.FirstOrDefault() ?? string.Empty;
    }

    private static IReadOnlyList<string> ExtractMeaningfulLines(params string[] outputs)
    {
        var lines = new List<string>();

        foreach (var output in outputs)
        {
            if (string.IsNullOrWhiteSpace(output))
            {
                continue;
            }

            foreach (var rawLine in output.Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
            {
                if (string.IsNullOrWhiteSpace(rawLine))
                {
                    continue;
                }

                var line = rawLine.Trim();
                if (ShouldIgnoreCommandLine(line))
                {
                    continue;
                }

                lines.Add(line);
            }
        }

        return lines.Count == 0 ? ["Command completed without textual output."] : lines;
    }

    private static bool ShouldIgnoreCommandLine(string line)
    {
        if (line.Length == 0)
        {
            return true;
        }

        if (line.Any(ch => ch == 'Γ' || ch == 'û' || ch == 'Æ'))
        {
            return true;
        }

        var letterOrDigitCount = line.Count(char.IsLetterOrDigit);
        if (letterOrDigitCount == 0)
        {
            return true;
        }

        var noiseCount = line.Count(ch =>
            ch is '|' or '/' or '\\' or '-' or '─' or '█' or '%' ||
            ch == '.');

        return noiseCount > letterOrDigitCount && line.Contains("KB", StringComparison.OrdinalIgnoreCase);
    }

    private static bool ContainsNoPackageFound(CommandResult result)
    {
        var message = string.Join(
            Environment.NewLine,
            new[] { result.StdOut, result.StdErr }.Where(static value => !string.IsNullOrWhiteSpace(value)));

        return message.Contains("No package found matching input criteria.", StringComparison.OrdinalIgnoreCase);
    }

    private CommandRequest CreateStreamingCommandRequest(string command, string operationId, IReadOnlyList<string> arguments, CancellationToken cancellationToken)
    {
        return new CommandRequest
        {
            Command = command,
            Arguments = arguments,
            OnOutput = line => LogInstallOutputAsync(operationId, line, cancellationToken)
        };
    }

    private Task LogInstallOutputAsync(string operationId, string line, CancellationToken cancellationToken)
    {
        var trimmedLine = line?.Trim() ?? string.Empty;
        if (ShouldIgnoreCommandLine(trimmedLine))
        {
            return Task.CompletedTask;
        }

        return OperationLogger.LogAsync(operationId, "SystemSetup", trimmedLine, cancellationToken);
    }

    private async Task<CommandResult> RunLoggedCommandAsync(string operationId, string description, CommandRequest request, CancellationToken cancellationToken)
    {
        await OperationLogger.LogAsync(operationId, "SystemSetup", $"Running command: {description}", cancellationToken);
        return await CommandRunner.RunAsync(request, cancellationToken);
    }

    private async Task RunProgressHeartbeatAsync(string operationId, string action, string componentName, CancellationToken cancellationToken)
    {
        var startedAt = DateTimeOffset.UtcNow;

        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromSeconds(3), cancellationToken);
                var elapsed = DateTimeOffset.UtcNow - startedAt;
                await OperationLogger.LogAsync(
                    operationId,
                    "SystemSetup",
                    $"{action} in progress component={componentName}, elapsed={Math.Max(1, (int)elapsed.TotalSeconds)}s",
                    cancellationToken);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private static async Task IgnoreCancellationAsync(Task task)
    {
        try
        {
            await task;
        }
        catch (OperationCanceledException)
        {
        }
    }

    private enum SetupStatus
    {
        NotInstalled,
        Installed,
        Installing
    }

    private sealed record SetupComponent(string Key, string DisplayName, IReadOnlyList<string> ServiceAliases);
}
